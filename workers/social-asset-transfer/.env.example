# Mac Mini worker env vars — copy this to .env on the Mac Mini and
# fill in. The worker does NOT inherit Vercel's env; it has its own
# service account + tokens because it runs locally.

# Firebase admin SDK — paste the SERVICE ACCOUNT JSON contents as a
# single-line string. Same JSON you'd get out of Firebase console
# "Generate new private key", just stringified.
FIREBASE_SERVICE_ACCOUNT=

# Database URL — must match the project the dashboard uses.
FIREBASE_DATABASE_URL=https://viewix-capacity-tracker-default-rtdb.asia-southeast1.firebasedatabase.app

# ── Frame.io auth ───────────────────────────────────────────────────
# Viewix's Frame.io account is V4-migrated and Frame-managed (NOT on the
# Adobe Admin Console), so the supported auth is a Legacy Developer
# Token. Verified working against the V4 API 2026-05-21.
#
# FRAMEIO_AUTH_MODE:
#   legacy (default) — Bearer <token> + header x-frameio-legacy-token-auth: true.
#   s2s              — Adobe IMS Server-to-Server. NOT implemented; only
#                      relevant if the account ever moves under the Adobe
#                      Admin Console. Selecting it throws a clear error.
FRAMEIO_AUTH_MODE=legacy

# Legacy developer token (read-only). Generate at developer.frame.io →
# Developer Tools → Tokens. Scopes: Accounts:Read + Assets:Read is enough
# (the worker only reads originals — never grant write/delete). The token
# does not expire, but it is a transitional mechanism — see README.
FRAMEIO_DEVELOPER_TOKEN=

# Frame.io account id (UUID) — used in /v4/accounts/{id}/files/{fileId}.
# Get it from `GET /v4/accounts` (the `id` field) or `npm run
# preflight:frameio`, which prints it.
FRAMEIO_ACCOUNT_ID=

# Optional: a known Frame.io file id, so `npm run preflight:frameio`
# tests the full media-resolution path (not just auth).
# FRAMEIO_TEST_FILE_ID=

# Zernio API key. Same key used by Vercel (see Vercel env vars). The
# worker uses it directly because it talks to Zernio /media/presign
# without going through Vercel.
ZERNIO_API_KEY=

# Optional override for Zernio's base URL — use the staging URL during
# the verification pilot.
# ZERNIO_BASE_URL=https://zernio.com/api/v1

# Slack webhook for #video-deliveries — where the worker pings on
# transfer failures (after 3 retries) + on worker startup. Reuse the
# same webhook you use elsewhere or wire a dedicated one.
SLACK_VIDEO_DELIVERIES_WEBHOOK_URL=

# Worker id — used in /socialAssets/{key}.claimedBy so you can tell
# which instance claimed a job if you ever scale to multiple workers.
# Default = `${hostname}-${pid}` at startup if unset.
# WORKER_ID=mac-mini-1
