{
  "rules": {
    ".read": "auth != null && auth.token.role != null",
    ".write": "auth != null && auth.token.role != null",

    "deliveries": {
      // Public share links (/d/{shortId}/...) scan this collection to find
      // the record whose `shortId` field matches. Allow listing to any
      // authenticated user (including anonymous) so the public view
      // can resolve shortIds. Individual deliveries are already readable
      // per-record below; collection-level read only leaks the small
      // amount of summary metadata already exposed per share URL.
      ".read": "auth != null",
      ".indexOn": ["shortId"],
      "$deliveryId": {
        ".read": "auth != null",
        "videos": {
          "$idx": {
            "revision1": { ".write": "auth != null" },
            "revision2": { ".write": "auth != null" }
          }
        }
      }
    },

    "preproduction": {
      "metaAds": {
        // Same pattern as /deliveries: public share links at /p/{shortId}
        // need to scan by shortId. Index it and allow the list read.
        ".read": "auth != null",
        ".indexOn": ["shortId"],
        "$projectId": {
          ".read": "auth != null",
          "clientFeedback": {
            ".write": "auth != null"
          }
        }
      },
      "socialOrganic": {
        // Mirror of metaAds — the Social Organic public view uses the
        // same /p/{shortId} pattern and does a collection scan.
        ".read": "auth != null",
        ".indexOn": ["shortId"],
        "$projectId": {
          ".read": "auth != null",
          "preproductionDoc": {
            "clientFeedback": {
              ".write": "auth != null"
            }
          }
        }
      },
      "feedbackLog": {
        ".write": "auth != null"
      }
    },

    "accounts": {
      ".read": "auth != null"
    },

    "sales": {
      // Public payment page at /s/{shortId} scans this collection by shortId
      // (same pattern as /deliveries). The page itself never writes — writes
      // happen server-side via the admin SDK (create-payment-intent creates
      // no record; stripe-webhook marks `paid` after signature verification).
      ".read": "auth != null",
      ".indexOn": ["shortId"]
    },

    "foundersData": {
      ".read": "auth != null && auth.token.role == 'founders'",
      ".write": "auth != null && auth.token.role == 'founders'"
    }
  }
}
