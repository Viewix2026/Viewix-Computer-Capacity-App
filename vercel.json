{
  "functions": {
    "api/preproduction.js": {
      "maxDuration": 300
    },
    "api/meeting-feedback.js": {
      "maxDuration": 120
    },
    "api/social-organic.js": {
      "maxDuration": 300
    },
    "api/fathom-webhook.js": {
      "maxDuration": 120
    },
    "api/whisper.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/check-contacts",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/sync-weekly-wins",
      "schedule": "0 21 * * *"
    }
  ],
  "rewrites": [
    { "source": "/d/:rest*", "destination": "/index.html" },
    { "source": "/p/:rest*", "destination": "/index.html" }
  ]
}
