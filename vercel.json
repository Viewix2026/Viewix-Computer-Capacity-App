{
  "functions": {
    "api/preproduction.js": {
      "maxDuration": 300
    },
    "api/meeting-feedback.js": {
      "maxDuration": 120
    },
    "api/social-organic.js": {
      "maxDuration": 300
    },
    "api/fathom-webhook.js": {
      "maxDuration": 120
    },
    "api/whisper.js": {
      "maxDuration": 60
    },
    "api/apify-webhook.js": {
      "maxDuration": 300
    },
    "api/stripe-webhook.js": {
      "maxDuration": 30
    },
    "api/meta-ads.js": {
      "maxDuration": 300
    },
    "api/founders-advisor.js": {
      "maxDuration": 300
    },
    "api/sync-attio-cache.js": {
      "maxDuration": 300
    },
    "api/roll-overdue-edits.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/check-contacts",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/founders-advisor",
      "schedule": "0 22 * * 0"
    },
    {
      "path": "/api/sync-attio-cache",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/roll-overdue-edits",
      "schedule": "0 20 * * *"
    }
  ],
  "rewrites": [
    { "source": "/d/:rest*", "destination": "/index.html" },
    { "source": "/p/:rest*", "destination": "/index.html" },
    { "source": "/s/:rest*", "destination": "/index.html" }
  ]
}
