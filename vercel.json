  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "viewixreviews.com.au" }],
      "destination": "/reviews.html"
    },
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "www.viewixreviews.com.au" }],
      "destination": "/reviews.html"
    },
    { "source": "/d/:rest*", "destination": "/index.html" },
    { "source": "/p/:rest*", "destination": "/index.html" },
    { "source": "/s/:rest*", "destination": "/index.html" },
    { "source": "/clients", "destination": "/index.html" },
    { "source": "/clients/", "destination": "/index.html" },
    { "source": "/clients/:rest*", "destination": "/index.html" },
    { "source": "/r", "destination": "/index.html" },
    { "source": "/r/", "destination": "/index.html" },
    { "source": "/r/:rest*", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.viewixreviews.com.au" }],
      "destination": "https://viewixreviews.com.au/:path*",
      "permanent": true
    },
    { "source": "/c", "destination": "/clients", "permanent": false },
    { "source": "/c/", "destination": "/clients/", "permanent": false },
    { "source": "/c/:rest*", "destination": "/clients/:rest*", "permanent": false }
  ]
}
